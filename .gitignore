# ------------------------------
# Python cache and bytecode
# ------------------------------
__pycache__/
*.py[cod]
*$py.class

# ------------------------------
# Build, packaging, and virtual envs
# ------------------------------
build/
dist/
*.egg-info/
.venv/
venv/
env/
ENV/

# Conda local env folders (if created inside repo)
.conda/

# ------------------------------
# Tool caches
# ------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# ------------------------------
# IDE and OS files
# ------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db

# ------------------------------
# Logs and local runtime artifacts
# ------------------------------
#*.log

# ------------------------------
# Training outputs and model artifacts
# ------------------------------
#results/
#results_*/
archive/
results_test/
!results/
!results/**

# Model checkpoints and histories
#**/best_params.pkl
#**/final_params.pkl
#**/loss_history.npz

# Generated figures (commonly created under results folders)
#results/**/*.png

# ------------------------------
# Optional: avoid committing compressed artifacts
# ------------------------------
*.zip
*.tar
*.gz
*.7z

# ------------------------------
# Local-only files (do not publish)
# ------------------------------
_patch_docs.py
GITHUB_WORKFLOW.md
github_workflow.md
DOCUMENTATION.md
documentation.md